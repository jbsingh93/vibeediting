{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "strict": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    // NOT noUncheckedIndexedAccess: the import graph includes template/src components (the
    // bundled demo comp + BrandContext/KineticCaptions), which compile under the template's
    // own tsconfig (strict, but without that flag). Our own files are written guard-clean.
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  // template files enter the program via imports (demo comp, BrandContext) — no wholesale include.
  "include": ["src"]
}
