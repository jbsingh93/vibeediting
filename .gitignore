# --- internal build contract: NEVER published, NEVER pushed (doc-of-record lives locally) ---
DEV-DOCS/

# --- node / build ---
node_modules/
dist/
*.log
*.tsbuildinfo
*.tgz

# NOTE: ui-dist/ is intentionally NOT ignored — the prebuilt UI client is
# committed and shipped in the npm package (aabclitool pattern).

# --- env & secrets ---
.env
.env.local

# --- generated machine-specific artifacts (suite/probe writes; must never ship in template) ---
template/capabilities/_env/ffmpeg-capabilities.json
template/.vibe/
template/out/

# --- test & coverage artifacts ---
coverage/
.vitest-cache/
test-artifacts/
test-results/

# --- gstack skill pack (project-local third-party install via setup --local; never vendor into the tree) ---
.claude/skills/gstack*/
.claude/skills/_gstack-command/

# --- Playwright MCP browser output (live-QA walks; never committed) ---
.playwright-mcp/

# --- OS noise ---
.DS_Store
Thumbs.db

# --- scratch output ---
out/
