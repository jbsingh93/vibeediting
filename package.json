{
  "name": "vibeediting",
  "version": "0.0.0",
  "description": "JBS Vibe Editing — AI video editing in your browser, driven by your own Claude Code (or Codex CLI) and a battle-tested local media engine. Source-available, free for non-commercial use.",
  "type": "module",
  "bin": {
    "vibe": "dist/bin/vibe.js"
  },
  "files": [
    "dist",
    "ui-dist",
    "template",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/vibe.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "npm run build && changeset publish"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "enquirer": "^2.4.1",
    "open": "^11.0.0",
    "ora": "^9.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.0",
    "tsup": "^8.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "video-editing",
    "ai",
    "remotion",
    "claude",
    "claude-code",
    "codex",
    "agent",
    "captions",
    "short-form",
    "cli"
  ],
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Julian Bent Singh <dinegenboss@gmail.com> (https://github.com/jbsingh93)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jbsingh93/vibeediting.git"
  },
  "homepage": "https://github.com/jbsingh93/vibeediting#readme",
  "bugs": {
    "url": "https://github.com/jbsingh93/vibeediting/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
