{
  "name": "vibeediting",
  "version": "0.1.3",
  "description": "JBS Vibe Editing — AI video editing in your browser, driven by your own Claude Code (or Codex CLI) and a battle-tested local media engine. Source-available, free for non-commercial use.",
  "type": "module",
  "bin": {
    "vibe": "dist/bin/vibe.js"
  },
  "files": [
    "dist",
    "ui-dist",
    "template",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/vibe.ts",
    "typecheck": "tsc --noEmit && tsc -p ui-app --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "ui:build": "vite build --config ui-app/vite.config.ts",
    "ui:dev": "vite --config ui-app/vite.config.ts",
    "prepublishOnly": "npm run build && npm run ui:build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "npm run build && npm run ui:build && changeset publish"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "commander": "^14.0.3",
    "enquirer": "^2.4.1",
    "fastify": "^5.8.5",
    "open": "^11.0.0",
    "ora": "^9.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.0",
    "@gsap/react": "^2.1.2",
    "@playwright/mcp": "^0.0.75",
    "@playwright/test": "^1.49.0",
    "@remotion/captions": "^4.0.461",
    "@remotion/paths": "^4.0.461",
    "@remotion/player": "^4.0.461",
    "@remotion/transitions": "^4.0.461",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.0",
    "globals": "^17.6.0",
    "gsap": "^3.15.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remotion": "^4.0.461",
    "tsup": "^8.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  },
  "keywords": [
    "video-editing",
    "ai",
    "remotion",
    "claude",
    "claude-code",
    "codex",
    "agent",
    "captions",
    "short-form",
    "cli"
  ],
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Julian Bent Singh <dinegenboss@gmail.com> (https://github.com/jbsingh93)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jbsingh93/vibeediting.git"
  },
  "homepage": "https://github.com/jbsingh93/vibeediting#readme",
  "bugs": {
    "url": "https://github.com/jbsingh93/vibeediting/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
